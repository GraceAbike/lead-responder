# Production environment variables for AI Lead Responder
# Copy this file to .env and fill in your actual values

# Database (use Neon PostgreSQL for production)
# Example: postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/neondb?sslmode=require

# OpenAI API Key for AI-powered responses
OPENAI_API_KEY=sk-proj-...

# Twilio SMS credentials (optional, for SMS confirmations)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Dashboard security
DASHBOARD_PASSWORD=your_secure_dashboard_password
SECRET_KEY=your_random_secret_key_min_32_chars

# Optional: Trial configuration (days before requiring payment)
TRIAL_DAYS=14
